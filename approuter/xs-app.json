{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/api/(.*)$",
      "target": "$1",
      "destination": "node-backend-api",
      "authenticationType": "xsuaa",
      "scope": "$XSAPPNAME.Admin"
    },
    {
      "source": "^/(.*)$",
      "target": "$1",
      "localDir": "build",
      "authenticationType": "xsuaa",
      "scope": "$XSAPPNAME.Viewer"
    }
  ]
}